@{
    ViewData["Title"] = "Dashboard IT Admin";
    Layout = "_Layout";
}

@section Header {
    <meta name="description" content="Dashboard quản trị IT - quản lý tài khoản và hệ thống LMS" />
    <style>
        .builder-item { padding: 10px 14px; background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 8px; cursor: grab; display: flex; align-items: center; gap: 10px; }
        .builder-item:hover { border-color: #3b82f6; background: #eff6ff; }
        .builder-item.dragging { opacity: 0.5; border: 2px dashed #3b82f6 !important; }
        .drop-zone-active { background: rgba(59, 130, 246, 0.1) !important; border: 2px dashed #3b82f6 !important; min-height: 40px; }
        .structure-module { background: #fff; border-radius: 10px; border: 1px solid #e2e8f0; margin-bottom: 15px; overflow: hidden; }
        .structure-module-header { padding: 12px 16px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; }
        .structure-module-body { padding: 10px 16px; min-height: 40px; }
        .structure-item { padding: 8px 12px; border: 1px solid #f1f5f9; border-radius: 6px; margin-bottom: 5px; display: flex; justify-content: space-between; font-size: 13px; }
        .badge-level { font-size: 10px; padding: 2px 6px; border-radius: 4px; font-weight: 700; }
        .level-1 { background: #dcfce7; color: #166534; }
        .level-2 { background: #fef9c3; color: #854d0e; }
        .level-3 { background: #fee2e2; color: #991b1b; }
    </style>
}

<div class="page-header">
    <div>
        <div class="page-title" id="pageTitle">Tổng quan hệ thống</div>
        <div class="page-subtitle" id="pageSubtitle">Giám sát và quản lý hạ tầng LMS</div>
    </div>
    <div class="header-actions">
        <button class="btn btn-secondary" data-permission="users.manage" onclick="openBulkDeptModal()">
            🚀 Đẩy NV vào phòng ban
        </button>
        <button class="btn btn-primary" data-permission="users.manage" onclick="navigate('users'); openModal('createUserModal');">
            👤 Tạo tài khoản
        </button>
    </div>
</div>

<div class="content-area">
    <!-- Nav Pills Removed (now handled by sidebar) -->

    <!-- ====== PAGE: Overview ====== -->
    <div id="overview" class="page-section fade-in">
        <div class="stats-grid" id="itStatsGrid">
            <div class="loading-overlay"><div class="spinner"></div></div>
        </div>
        <div class="grid-2">
            <div class="card">
                <div class="card-header"><div class="card-title">📊 Phân bổ người dùng</div></div>
                <div class="card-body">
                    <div id="userChartEmpty" style="display:none;padding:40px;text-align:center;color:#94a3b8">Chưa có dữ liệu</div>
                    <canvas id="userChart" height="180"></canvas>
                </div>
            </div>
            <div class="card">
                <div class="card-header"><div class="card-title">🕒 Hoạt động gần đây</div></div>
                <div class="card-body" style="padding:0; position:relative; min-height:200px" id="recentLogs">
                    <div class="loading-overlay"><div class="spinner"></div></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Users ====== -->
    <div id="users" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px">
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
                    <div class="input-wrap" style="flex:1;min-width:200px">
                        <span class="input-icon">🔍</span>
                        <input id="userSearch" type="text" class="form-input with-icon" placeholder="Tìm tên, email, mã NV..." oninput="debouncedLoadUsers()">
                    </div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th style="width:40px"><input type="checkbox" id="selectAllUsers" onclick="toggleSelectAll(this)"></th>
                            <th>Nhân viên</th>
                            <th>Mã NV</th>
                            <th>Phòng ban</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="usersTable">
                        <tr><td colspan="7"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
            <div id="usersPagination" class="pagination"></div>
        </div>
    </div>

    <!-- ====== PAGE: Courses ====== -->
    <div id="courses" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px; display:flex; justify-content:space-between; align-items:center">
                <div class="input-wrap" style="flex:1; max-width:400px">
                    <span class="input-icon">🔍</span>
                    <input id="courseSearch" type="text" class="form-input with-icon" placeholder="Tìm tên khóa học..." oninput="debouncedLoadItCourses()">
                </div>
                <button class="btn btn-primary" onclick="openCreateCourseModal()">➕ Thêm Khóa Học</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Mã KH</th>
                            <th>Tên khóa học</th>
                            <th>Level</th>
                            <th>Danh mục</th>
                            <th>Bắt buộc</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="itCoursesTable">
                        <tr><td colspan="8"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Departments ====== -->
    <div id="departments" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px; display:flex; justify-content:flex-end">
                <button class="btn btn-primary" onclick="openCreateDeptModal()">➕ Thêm Phòng Ban</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tên phòng ban</th>
                            <th>Trưởng phòng</th>
                            <th>Số lượng NV</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="itDepartmentsTable">
                        <tr><td colspan="5"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Audit Logs ====== -->
    <div id="auditlogs" class="page-section" style="display:none">
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>Thời gian</th>
                            <th>Người thực hiện</th>
                            <th>Hành động</th>
                            <th>Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody id="fullAuditLogsTable">
                        <tr><td colspan="4"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
            <div id="auditPagination" class="pagination"></div>
        </div>
    </div>

    <!-- ====== PAGE: Categories ====== -->
    <div id="categories" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px; display:flex; justify-content:flex-end">
                <button class="btn btn-primary" onclick="openCreateCategoryModal()">➕ Thêm Danh Mục</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>ID</th><th>Tên danh mục</th><th>Khóa học</th><th>FAQ</th><th>Ngân hàng câu hỏi</th><th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="categoriesTable">
                        <tr><td colspan="6"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: FAQ ====== -->
    <div id="faqs" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px; display:flex; gap:12px; justify-content:space-between; align-items:center">
                <div class="input-wrap" style="flex:1; max-width:400px">
                    <span class="input-icon">🔍</span>
                    <input id="faqSearch" type="text" class="form-input with-icon" placeholder="Tìm câu hỏi..." oninput="debouncedLoadFaqs()">
                </div>
                <button class="btn btn-primary" onclick="openCreateFaqModal()">➕ Thêm FAQ</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th style="width:40%">Câu hỏi</th><th>Câu trả lời</th><th>Danh mục</th><th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="faqsTable">
                        <tr><td colspan="4"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Document Library ====== -->
    <div id="documents" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-header" style="border-bottom:none; padding-bottom:6px">
                <div>
                    <div class="card-title">📚 Kho tài liệu hệ thống</div>
                    <div class="card-subtitle">Quản lý kho chương, bài giảng và quiz trong toàn hệ thống.</div>
                </div>
            </div>
            <div class="card-body" style="padding-top:0">
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;justify-content:space-between">
                    <div style="display:flex;gap:10px;flex-wrap:wrap">
                        <button id="libraryTabModules" class="btn btn-primary" onclick="switchLibraryTab('modules')">🧩 Kho Chương</button>
                        <button id="libraryTabLessons" class="btn btn-secondary" onclick="switchLibraryTab('lessons')">📝 Kho Bài Giảng</button>
                        <button id="libraryTabExams" class="btn btn-secondary" onclick="switchLibraryTab('exams')">❓ Kho Quiz</button>
                    </div>
                    <button id="libraryCreateBtn" class="btn btn-primary" onclick="openLibraryCreateModal()">➕ Tạo mới</button>
                </div>
            </div>
        </div>

        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px">
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
                    <div class="input-wrap" style="flex:1;min-width:240px">
                        <span class="input-icon">🔍</span>
                        <input id="librarySearch" type="text" class="form-input with-icon" placeholder="Tìm theo tên chương, bài giảng, quiz hoặc khóa học..." oninput="renderDocumentLibrary()">
                    </div>
                    <select id="libraryDeptFilter" class="form-input" style="width:220px" onchange="renderDocumentLibrary()">
                        <option value="">Tất cả phòng ban</option>
                    </select>
                    <select id="libraryCourseFilter" class="form-input" style="width:260px" onchange="renderDocumentLibrary()">
                        <option value="">Tất cả khóa học</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="stats-grid" style="margin-bottom:16px">
            <div class="stat-card blue">
                <div class="stat-icon blue">🧩</div>
                <div class="stat-value" id="libraryModulesCount">0</div>
                <div class="stat-label">Tổng số chương</div>
            </div>
            <div class="stat-card green">
                <div class="stat-icon green">📝</div>
                <div class="stat-value" id="libraryLessonsCount">0</div>
                <div class="stat-label">Tổng số bài giảng</div>
            </div>
            <div class="stat-card cyan">
                <div class="stat-icon cyan">📎</div>
                <div class="stat-value" id="libraryAttachmentsCount">0</div>
                <div class="stat-label">Tổng số tài liệu</div>
            </div>
            <div class="stat-card orange">
                <div class="stat-icon orange">❓</div>
                <div class="stat-value" id="libraryExamsCount">0</div>
                <div class="stat-label">Tổng số Quiz</div>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead id="documentLibraryHead"></thead>
                    <tbody id="documentLibraryTable">
                        <tr><td colspan="6"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Approvals (Documents) ====== -->
    <div id="approvals" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-header">
                <div>
                    <div class="card-title">⚖️ Phê duyệt tài liệu đào tạo</div>
                    <div class="card-subtitle">Xem xét và phê duyệt các tài liệu (Chương, Bài giảng, Quiz) do Giảng viên/Manager gửi lên.</div>
                </div>
            </div>
            <div class="card-body" style="padding: 14px 20px; border-top: 1px solid #e2e8f0;">
                <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:center">
                    <div class="input-wrap" style="flex:1; min-width:200px">
                        <span class="input-icon">🔍</span>
                        <input id="approvalSearch" type="text" class="form-input with-icon" placeholder="Tìm tên tài liệu hoặc mã người tạo..." oninput="filterApprovals()">
                    </div>
                    <select id="approvalStatusFilter" class="form-input" style="width:180px" onchange="filterApprovals()">
                        <option value="Pending">Chờ duyệt</option>
                        <option value="Approved">Đã duyệt</option>
                        <option value="Rejected">Từ chối</option>
                        <option value="">Tất cả trạng thái</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tiêu đề</th>
                            <th>Loại</th>
                            <th>Người tạo</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="approvalsTable">
                        <tr><td colspan="6"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div id="analytics" class="page-section" style="display:none">
        <div class="grid-2" style="margin-bottom:20px">
            <div class="card">
                <div class="card-header"><div class="card-title">🏢 Nhân viên theo phòng ban</div></div>
                <div class="card-body"><canvas id="deptChart" height="220"></canvas></div>
            </div>
            <div class="card">
                <div class="card-header"><div class="card-title">📚 Khóa học theo danh mục</div></div>
                <div class="card-body"><canvas id="catChart" height="220"></canvas></div>
            </div>
        </div>
        <div class="grid-2" style="margin-bottom:20px">
            <div class="card">
                <div class="card-header"><div class="card-title">📈 Enrollment theo tháng (6 tháng gần nhất)</div></div>
                <div class="card-body"><canvas id="enrollChart" height="200"></canvas></div>
            </div>
            <div class="card">
                <div class="card-header"><div class="card-title">🎯 Tỷ lệ pass/fail Quiz</div></div>
                <div class="card-body">
                    <canvas id="examChart" height="180"></canvas>
                    <div id="examStatText" style="text-align:center; margin-top:10px; font-size:13px; color:#64748b"></div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><div class="card-title">🏆 Top 5 khóa học phổ biến nhất</div></div>
            <div class="card-body">
                <table class="lms-table">
                    <thead><tr><th>#</th><th>Tên khóa học</th><th>Số học viên</th></tr></thead>
                    <tbody id="topCoursesTable"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Backup ====== -->
    <div id="backup" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:20px">
                <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap">
                    <div>
                        <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px">Loại Backup</label>
                        <select id="backupTypeSelect" class="form-input" style="width:200px">
                            <option value="Full">Full Backup</option>
                            <option value="Incremental">Incremental</option>
                            <option value="Manual">Manual</option>
                        </select>
                    </div>
                    <div style="align-self:flex-end">
                        <button class="btn btn-primary" onclick="createBackup()">💾 Tạo Backup Ngay</button>
                    </div>
                    <div style="align-self:flex-end">
                        <button class="btn btn-secondary" onclick="loadBackupLogs()">🔄 Làm mới</button>
                    </div>
                </div>
                <div id="backupMsg" style="margin-top:12px; font-size:13px; color:#10b981"></div>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><div class="card-title">📜 Lịch sử Backup</div></div>
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr><th>ID</th><th>Tên file</th><th>Loại</th><th>Thời gian tạo</th></tr>
                    </thead>
                    <tbody id="backupLogsTable">
                        <tr><td colspan="4"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Permissions ====== -->
    <div id="permissions" class="page-section" style="display:none">
        <div class="card">
            <div class="card-header">
                <div>
                    <div class="card-title">🔑 Phân quyền chức năng</div>
                    <div class="card-subtitle">Chọn role hoặc người dùng, sau đó bấm vào từng khung để bật hoặc tắt chức năng.</div>
                </div>
            </div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:18px">
                <div class="grid-2">
                    <div class="form-group">
                        <label>Kiểu phân quyền</label>
                        <select id="permissionTargetType" class="form-input" onchange="onPermissionTargetTypeChange(); loadPermissionBoard();">
                            <option value="role">Phân quyền theo role</option>
                            <option value="user">Phân quyền theo người dùng</option>
                        </select>
                    </div>
                    <div id="permissionRoleWrap" class="form-group">
                        <label>Chọn role</label>
                        <select id="permissionRoleTarget" class="form-input" onchange="loadPermissionBoard()"></select>
                    </div>
                    <div id="permissionUserWrap" class="form-group" style="display:none">
                        <label>Chọn người dùng</label>
                        <select id="permissionUserTarget" class="form-input" onchange="loadPermissionBoard()"></select>
                    </div>
                </div>

                <div style="padding:14px 16px;border-radius:14px;background:#f8fafc;border:1px solid #e2e8f0">
                    <div style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.08em">Đối tượng đang chỉnh</div>
                    <div id="permissionBoardTitle" style="margin-top:6px;font-size:18px;font-weight:800;color:#0f172a">Chưa chọn đối tượng</div>
                </div>

                <div id="permissionsTable" class="permission-grid">
                    <div style="padding:24px;color:#94a3b8;text-align:center;grid-column:1/-1">Đang tải danh sách chức năng...</div>
                </div>
            </div>
        </div>
    </div>

    <div id="settings" class="page-section" style="display:none">
        <div class="card">
            <div class="card-header">
                <div class="card-title">⚙️ Cài đặt hệ thống</div>
                <button class="btn btn-secondary btn-sm" onclick="loadSettings()">Làm mới</button>
            </div>
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr><th>Khóa</th><th>Giá trị</th><th>Cập nhật lần cuối</th><th>Thao tác</th></tr>
                    </thead>
                    <tbody id="settingsTable">
                        <tr><td colspan="4"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Newsletter ====== -->
    <div id="newsletter" class="page-section" style="display:none">
        <div class="stats-grid" id="newsletterStats" style="margin-bottom:20px"></div>
        <div class="card">
            <div class="card-header"><div class="card-title">📧 Danh sách đăng ký Newsletter</div></div>
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr><th>Họ tên</th><th>Mã NV</th><th>Chức danh</th><th>Thao tác</th></tr>
                    </thead>
                    <tbody id="newsletterTable">
                        <tr><td colspan="4"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>


    <!-- ====== PAGE: Job Titles ====== -->
    <div id="jobtitles" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px; display:flex; justify-content:space-between; align-items:center">
                <div style="font-size:13px;color:#64748b">Quản lý chức danh nhân viên trong hệ thống</div>
                <button class="btn btn-primary" onclick="openCreateJobTitleModal()">➕ Thêm Chức Danh</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr><th>ID</th><th>Tên Chức Danh</th><th>Cấp Bậc (Grade)</th><th>Số NV Đang Dùng</th><th>Thao tác</th></tr>
                    </thead>
                    <tbody id="jobTitlesTable">
                        <tr><td colspan="5"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
