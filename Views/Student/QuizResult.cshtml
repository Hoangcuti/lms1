@{
    Layout = null;
    int userExamId = ViewBag.UserExamId;
    string examTitle = ViewBag.ExamTitle ?? "Kết quả bài kiểm tra";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@examTitle - Kết quả</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="~/js/app.js"></script>
    <style>
        :root {
            --brand: #2563eb;
            --brand-soft: rgba(37, 99, 235, 0.1);
            --bg: #f8fafc;
            --card-bg: rgba(255, 255, 255, 0.85);
            --text-main: #0f172a;
            --text-muted: #64748b;
            --success: #10b981;
            --error: #ef4444;
            --warning: #f59e0b;
            --glass-border: rgba(255, 255, 255, 0.5);
            --glass-shadow: 0 20px 50px rgba(15, 23, 42, 0.1);
        }

        * {
            box-sizing: border-box;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            margin: 0;
            background: var(--bg);
            color: var(--text-main);
            overflow-x: hidden;
        }

        .background-blob {
            position: fixed;
            top: -200px;
            right: -200px;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(37, 99, 235, 0.15) 0%, transparent 70%);
            z-index: -1;
            filter: blur(80px);
        }

        .wrap {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 24px;
            animation: fadeIn 0.8s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: var(--brand);
            font-weight: 700;
            font-size: 14px;
            margin-bottom: 32px;
            transition: transform 0.2s;
        }
        .back-link:hover { transform: translateX(-5px); }

        .header {
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 36px;
            font-weight: 800;
            margin: 0 0 12px;
            letter-spacing: -0.02em;
        }

        .header p {
            color: var(--text-muted);
            font-size: 16px;
            margin: 0;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 40px;
        }

        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            padding: 32px;
            box-shadow: var(--glass-shadow);
        }

        /* Score Circle Section */
        .score-wrap {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .progress-circle {
            position: relative;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: conic-gradient(var(--brand) 0%, #e2e8f0 0%);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 1s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 24px;
        }

        .progress-circle::after {
            content: '';
            position: absolute;
            width: 170px;
            height: 170px;
            background: white;
            border-radius: 50%;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
        }

        .score-text {
            position: relative;
            z-index: 10;
            font-size: 48px;
            font-weight: 800;
            color: var(--text-main);
        }

        .score-meta {
            font-size: 14px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-top: 32px;
            width: 100%;
        }

        .stat-item {
            padding: 20px;
            border-radius: 20px;
            background: white;
            border: 1px solid rgba(0,0,0,0.03);
            transition: transform 0.3s;
        }
        .stat-item:hover { transform: translateY(-5px); }

        .stat-val {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Evaluation Section */
        .eval-section {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .rank-badge {
            display: inline-block;
            padding: 12px 24px;
            border-radius: 16px;
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 16px;
            color: white;
            background: var(--brand);
            box-shadow: 0 10px 20px rgba(37,99,235,0.2);
        }

        .rank-note {
            font-size: 16px;
            line-height: 1.6;
            color: var(--text-muted);
            margin-bottom: 32px;
        }

        .filter-chips {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .chip {
            padding: 12px 20px;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            background: white;
            color: var(--text-main);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .chip:hover { border-color: var(--brand); }
        .chip.active {
            background: var(--brand);
            color: white;
            border-color: var(--brand);
            box-shadow: 0 8px 16px rgba(37,99,235,0.2);
        }

        /* Details Section */
        .details-title {
            font-size: 24px;
            font-weight: 800;
            margin: 40px 0 24px;
        }

        .q-card {
            background: white;
            border-radius: 24px;
            padding: 24px;
            margin-bottom: 20px;
            border: 1px solid #e2e8f0;
            transition: all 0.3s;
        }
        .q-card:hover { border-color: var(--brand); box-shadow: 0 10px 30px rgba(0,0,0,0.03); }

        .q-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }

        .q-num {
            font-size: 13px;
            font-weight: 700;
            color: var(--brand);
            background: var(--brand-soft);
            padding: 6px 12px;
            border-radius: 8px;
        }

        .op-list {
            display: grid;
            gap: 10px;
        }

        .op-item {
            padding: 16px 20px;
            border-radius: 16px;
            background: #f8fafc;
            border: 1.5px solid #f1f5f9;
            font-size: 15px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .op-item.correct { border-color: var(--success); background: #ecfdf5; color: #065f46; font-weight: 700; }
        .op-item.wrong { border-color: var(--error); background: #fef2f2; color: #991b1b; font-weight: 700; }
        .op-item.missed { border-color: var(--brand); background: #eff6ff; color: #1e40af; }

        .badge-mini {
            font-size: 10px;
            padding: 4px 8px;
            border-radius: 6px;
            text-transform: uppercase;
            font-weight: 800;
        }
        .badge-mini.correct { background: var(--success); color: white; }
        .badge-mini.wrong { background: var(--error); color: white; }

        @@media (max-width: 900px) {
            .hero-grid { grid-template-columns: 1fr; }
            .wrap { padding: 24px 16px; }
            .header h1 { font-size: 28px; }
        }
    </style>
</head>
<body>
    <div class="background-blob"></div>
    <div class="wrap">
        <a href="/Student/Index" class="back-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5m7-7-7 7 7 7"/></svg>
            Quay về Dashboard
        </a>

        <div class="header">
            <h1 id="viewTitle">@examTitle</h1>
            <p>Dưới đây là phân tích chi tiết kết quả bài làm của bạn.</p>
        </div>

        <div class="hero-grid">
            <!-- Left Card: Score -->
            <section class="glass-card score-wrap">
                <div class="progress-circle" id="progressCircle">
                    <div class="score-text" id="scoreText">0%</div>
                </div>
                <div class="score-meta" id="scoreMeta">Đang tải dữ liệu...</div>

                <div class="stats-grid">
                    <div class="stat-item">
                        <div class="stat-val" id="statCorrect" style="color: var(--success)">0</div>
                        <div class="stat-label">Câu Đúng</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-val" id="statWrong" style="color: var(--error)">0</div>
                        <div class="stat-label">Câu Sai</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-val" id="statEmpty" style="color: var(--text-muted)">0</div>
                        <div class="stat-label">Bỏ trống</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-val" id="statRank">--</div>
                        <div class="stat-label">Xếp loại</div>
                    </div>
                </div>
            </section>

            <!-- Right Card: Evaluation -->
            <section class="glass-card eval-section">
                <div class="muted" style="margin-bottom: 8px; text-transform: uppercase; font-weight: 700; letter-spacing: 0.1em; font-size: 12px;">Đánh giá tổng quát</div>
                <div id="rankBadge" class="rank-badge">--</div>
                <div class="rank-note" id="rankNote">Đang tính toán kết quả dựa trên các tiêu chí...</div>

                <div class="muted" style="margin-bottom: 16px; font-weight: 700; font-size: 13px; color: var(--text-main)">Lọc xem lại câu hỏi:</div>
                <div class="filter-chips">
                    <button class="chip active" onclick="setFilter('all', this)">Tất cả</button>
                    <button class="chip" onclick="setFilter('correct', this)">Câu đúng</button>
                    <button class="chip" onclick="setFilter('wrong', this)">Câu sai</button>
                    <button class="chip" onclick="setFilter('empty', this)">Bỏ trống</button>
                </div>
            </section>
        </div>

        <h2 class="details-title">Chi tiết từng câu hỏi</h2>
        <div id="detailsHost"></div>
    </div>

    <script>
        const userExamId = @userExamId;
        let resultData = null;
        let currentFilter = 'all';

        async function init() {
            try {
                resultData = await apiFetch(`/api/student/quiz-results/${userExamId}`);
                
                // Fix logic bug visually if score is 0 but there are correct answers
                if (resultData.score === 0 && resultData.correctCount > 0) {
                    const totalQ = resultData.totalQuestions || 1;
                    resultData.score = Math.round((resultData.correctCount / totalQ) * 100);
                }

                renderSummary();
                renderDetails();
                
                if (resultData.score >= resultData.passScore) {
                    launchConfetti();
                }
            } catch (err) {
                console.error(err);
                document.getElementById('scoreMeta').textContent = "Lỗi tải kết quả.";
            }
        }

        function renderSummary() {
            const score = resultData.score || 0;
            const circle = document.getElementById('progressCircle');
            const scoreText = document.getElementById('scoreText');
            
            // Animation for circle
            circle.style.background = `conic-gradient(var(--brand) ${score}%, #e2e8f0 ${score}% 100%)`;
            
            // Counter animation
            let current = 0;
            const step = Math.max(1, Math.floor(score / 50));
            const timer = setInterval(() => {
                if (current >= score) {
                    scoreText.textContent = score + '%';
                    clearInterval(timer);
                } else {
                    current += step;
                    scoreText.textContent = current + '%';
                }
            }, 20);

            document.getElementById('scoreMeta').textContent = `Mục tiêu: ${resultData.passScore}% • Ngày thi: ${fmtDateTime(resultData.endTime)}`;
            document.getElementById('statCorrect').textContent = resultData.correctCount;
            document.getElementById('statWrong').textContent = resultData.incorrectCount;
            document.getElementById('statEmpty').textContent = resultData.unansweredCount;
            document.getElementById('statRank').textContent = resultData.evaluation.ranking;
            
            const badge = document.getElementById('rankBadge');
            badge.textContent = resultData.evaluation.ranking;
            if (score >= resultData.passScore) {
                badge.style.background = 'var(--success)';
                badge.style.boxShadow = '0 10px 20px rgba(16,185,129,0.2)';
            } else {
                badge.style.background = 'var(--error)';
                badge.style.boxShadow = '0 10px 20px rgba(239,68,68,0.2)';
            }
            
            document.getElementById('rankNote').textContent = resultData.evaluation.note;
            document.getElementById('viewTitle').textContent = resultData.examTitle;
        }

        function setFilter(filter, el) {
            currentFilter = filter;
            document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
            el.classList.add('active');
            renderDetails();
        }

        function renderDetails() {
            const items = (resultData.details || []).filter(item => 
                currentFilter === 'all' || 
                (currentFilter === 'correct' && item.isCorrect) || 
                (currentFilter === 'wrong' && item.isAnswered && !item.isCorrect) || 
                (currentFilter === 'empty' && !item.isAnswered)
            );
            
            const host = document.getElementById('detailsHost');
            if (!items.length) {
                host.innerHTML = '<div class="glass-card" style="text-align:center; padding:48px; color:var(--text-muted)">Không có câu hỏi nào khớp với bộ lọc này.</div>';
                return;
            }

            host.innerHTML = items.map((item, idx) => `
                <div class="q-card" style="animation: fadeIn 0.5s ease backwards ${idx * 0.05}s">
                    <div class="q-header">
                        <span class="q-num">Câu ${idx + 1}</span>
                        ${item.isCorrect ? '<span class="badge-mini correct">Chính xác</span>' : (item.isAnswered ? '<span class="badge-mini wrong">Sai rồi</span>' : '<span class="badge-mini">Chưa chọn</span>')}
                    </div>
                    <h3 style="margin:0 0 20px; font-weight:700; line-height:1.4">${escapeHtml(item.questionText || '')}</h3>
                    <div class="op-list">
                        ${item.options.map(o => {
                            let cls = 'op-item';
                            let icon = '';
                            if (o.isCorrect) {
                                cls += ' correct';
                                icon = '✅ ';
                            } else if (o.isSelected && !o.isCorrect) {
                                cls += ' wrong';
                                icon = '❌ ';
                            } else if (!item.isAnswered && o.isCorrect) {
                                cls += ' missed';
                            }
                            return `<div class="${cls}">
                                <span style="font-size:18px">${icon}</span>
                                <div style="flex:1">${escapeHtml(o.optionText || '')}</div>
                                ${o.isSelected ? '<span class="badge-mini" style="background:#000;color:#fff;font-size:8px">Lựa chọn của bạn</span>' : ''}
                            </div>`;
                        }).join('')}
                    </div>
                </div>
            `).join('');
        }

        function launchConfetti() {
            try {
                const colors = ['#2563eb', '#10b981', '#f59e0b', '#8b5cf6'];
                for (let i = 0; i < 50; i++) {
                    const node = document.createElement('div');
                    node.style.position = 'fixed';
                    node.style.top = '-20px';
                    node.style.left = `${Math.random() * 100}vw`;
                    node.style.width = '10px';
                    node.style.height = '14px';
                    node.style.background = colors[Math.floor(Math.random() * colors.length)];
                    node.style.transform = `rotate(${Math.random() * 360}deg)`;
                    node.style.borderRadius = '2px';
                    node.style.zIndex = '10000';
                    node.style.pointerEvents = 'none';
                    document.body.appendChild(node);

                    const duration = 2000 + Math.random() * 2000;
                    const destX = (Math.random() - 0.5) * 500;
                    
                    node.animate([
                        { transform: `translate(0, 0) rotate(0)`, opacity: 1 },
                        { transform: `translate(${destX}px, ${window.innerHeight + 50}px) rotate(${720 + Math.random() * 720}deg)`, opacity: 0 }
                    ], {
                        duration: duration,
                        easing: 'cubic-bezier(0.1, 0.8, 0.3, 1)'
                    }).onfinish = () => node.remove();
                }
            } catch(e) {}
        }

        document.addEventListener('DOMContentLoaded', () => init());
    </script>
</body>
</html>
