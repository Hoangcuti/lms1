                    <h3>${escapeHtml(b.badgeName || 'Huy hiệu')}</h3>
                    <div class="meta-line">${escapeHtml(b.description || '--')}</div>
                    <div class="meta-line">Nhận ngày ${fmtDate(b.earnedDate)}</div>
                </div>`).join('') : renderEmpty('Bạn chưa có huy hiệu nào.');
            document.getElementById('leaderboardList').innerHTML = (data.leaderboard?.length ?? 0) ? data.leaderboard.map((u, idx) => `
                <div class="rank-item"><div><strong>#${idx + 1}</strong> ${escapeHtml(u.fullName || 'N/A')}</div><div class="badge badge-blue">${fmtNumber(u.totalPoints || 0)} điểm</div></div>`).join('') : renderEmpty('Chưa có dữ liệu xếp hạng.');
        }

        async function loadSurveys() {
            const data = await apiFetch('/api/student/surveys');
            document.getElementById('surveysList').innerHTML = data.length ? data.map(s => `
                <div class="survey-card">
                    <h3>${escapeHtml(s.title || 'Khảo sát')}</h3>
                    <div class="meta-line">${escapeHtml(s.description || '--')}</div>
                    <div class="meta-line">Hạn: ${fmtDate(s.expiredDate)}</div>
                    <div class="card-actions">${s.isCompleted ? '<span class="badge badge-success">Đã hoàn thành</span>' : s.isExpired ? '<span class="badge badge-danger">Đã hết hạn</span>' : `<button class="btn btn-primary btn-sm" type="button" onclick="openSurveyModal(${s.surveyId}, ${JSON.stringify(s.title || '')})">Trả lời khảo sát</button>`}</div>
                </div>`).join('') : renderEmpty('Hiện chưa có khảo sát nào.');
        }

        function openSurveyModal(surveyId, title) {
            state.selectedSurveyId = surveyId;
            state.selectedSurveyRating = 5;
            document.getElementById('surveyModalTitle').textContent = title || 'Khảo sát';
            document.getElementById('surveyAnswer').value = '';
            document.getElementById('surveyStars').innerHTML = Array.from({ length: 5 }, (_, i) => `<span class="star ${i < 5 ? 'active' : ''}" onclick="setSurveyRating(${i + 1})">★</span>`).join('');
            openModal('surveyModal');
        }

        function setSurveyRating(value) {
            state.selectedSurveyRating = value;
            document.querySelectorAll('#surveyStars .star').forEach((star, idx) => star.classList.toggle('active', idx < value));
        }

        async function submitSurvey() {
            if (!state.selectedSurveyId) return;
            const answerData = JSON.stringify({ rating: state.selectedSurveyRating, comment: document.getElementById('surveyAnswer').value.trim() });
            await apiFetch(`/api/student/surveys/${state.selectedSurveyId}/submit`, { method: 'POST', body: JSON.stringify({ answerData }) });
            closeModal('surveyModal');
            showToast('Gửi khảo sát thành công.');
            await loadSurveys();
        }

        async function loadNotifications(silent) {
            const data = await apiFetch('/api/student/notifications');
            state.notifications = data.notifications || [];
            document.getElementById('notifBadge').textContent = fmtNumber(data.unreadCount || 0);
            document.getElementById('notificationsList').innerHTML = state.notifications.length ? state.notifications.map(n => `
                <div class="notif-card">
                    <h3>${escapeHtml(n.title || 'Thông báo')}</h3>
                    <div class="meta-line">${n.isRead ? 'Đã đọc' : 'Chưa đọc'}</div>
                    <div class="card-actions">${n.isRead ? '' : `<button class="btn btn-secondary btn-sm" type="button" onclick="markNotifRead(${n.id})">Đánh dấu đã đọc</button>`}</div>
                </div>`).join('') : renderEmpty('Bạn chưa có thông báo nào.');
            if (!silent) showToast('Đã tải danh sách thông báo.', 'info', { duration: 1800 });
        }

        async function markNotifRead(id) {
            await apiFetch(`/api/student/notifications/${id}/read`, { method: 'POST' });
            await loadNotifications(true);
            await loadDashboard();
        }

        async function markAllNotifRead() {
            await apiFetch('/api/student/notifications/read-all', { method: 'POST' });
            showToast('Đã đánh dấu tất cả thông báo là đã đọc.');
            await loadNotifications(true);
            await loadDashboard();
        }

        async function loadProfile() {
            const data = await apiFetch('/api/student/profile');
            document.getElementById('profileFullName').value = data.fullName || '';
            document.getElementById('profileEmail').value = data.email || '';
            document.getElementById('profileUsername').value = data.username || '';
            document.getElementById('profileEmployeeCode').value = data.employeeCode || '';
            document.getElementById('profileDepartment').value = data.department || '';
            document.getElementById('profileJobTitle').value = data.jobTitle || '';
        }

        async function saveProfile() {
            await apiFetch('/api/student/profile', { method: 'PUT', body: JSON.stringify({ fullName: document.getElementById('profileFullName').value.trim(), email: document.getElementById('profileEmail').value.trim() }) });
            showToast('Cập nhật hồ sơ thành công.');
            await loadProfileSummary();
        }

        async function changePassword() {
            const oldPassword = document.getElementById('oldPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            if (newPassword !== confirmPassword) {
                showToast('Mật khẩu xác nhận không khớp.', 'warning');
                return;
            }
            await apiFetch('/api/student/change-password', { method: 'POST', body: JSON.stringify({ oldPassword, newPassword }) });
            document.getElementById('oldPassword').value = '';
            document.getElementById('newPassword').value = '';
            document.getElementById('confirmPassword').value = '';
            showToast('Đổi mật khẩu thành công.');
        }

        document.addEventListener('DOMContentLoaded', initStudentDashboard);
    </script>
</body>
</html>
