        async function loadStudySchedule() {
            try {
                const [offlineEvents, upcomingQuizzes] = await Promise.all([
                    apiFetch('/api/student/offline-events'),
                    apiFetch('/api/student/upcoming-quizzes')
                ]);

                // Render Offline Events
                const offlineHtml = offlineEvents.length ? offlineEvents.map(ev => `
                    <div class="schedule-item">
                        <div style="text-align:center; padding:10px; background:#f1f5f9; border-radius:12px;">
                            <div class="schedule-day">${new Date(ev.startTime).toLocaleDateString('vi-VN', { weekday: 'short' })}</div>
                            <div style="font-size:20px; font-weight:800; color:#1e293b;">${new Date(ev.startTime).getDate()}</div>
                            <div class="meta-line">Tháng ${new Date(ev.startTime).getMonth() + 1}</div>
                        </div>
                        <div style="flex:1">
                            <div style="display:flex; justify-content:space-between; align-items:start">
                                <div>
                                    <div style="font-size:16px; font-weight:800; color:#0f172a">${escapeHtml(ev.courseTitle)}</div>
                                    <div class="meta-line">📍 ${escapeHtml(ev.location || 'Chưa xác định')}</div>
                                </div>
                                <div style="text-align:right">
                                    <div class="badge badge-blue">${escapeHtml(ev.shift || 'Toàn thời gian')}</div>
                                    <div style="font-size:12px; font-weight:700; color:var(--primary); margin-top:4px;">${fmtTime(ev.startTime)} - ${fmtTime(ev.endTime)}</div>
                                </div>
                            </div>
                            <div style="margin-top:10px; padding-top:10px; border-top:1px dashed var(--border); display:flex; justify-content:space-between; align-items:center">
                                <div style="font-size:12px; color:var(--text-secondary)">👤 Phụ trách: <strong>${escapeHtml(ev.instructor || 'Giảng viên')}</strong></div>
                                ${ev.isRegistered ? 
                                    (ev.attendanceStatus === 'Present' ? 
                                        `<span class="badge badge-success">✅ Đã điểm danh</span>` :
                                        (isAttendanceTime(ev) ? 
                                            `<button class="btn btn-primary btn-sm" onclick="studentCheckIn(${ev.eventId})">📍 Điểm danh ngay</button>` : 
                                            `<span class="badge badge-blue">Đã đăng ký</span>`)) 
                                    : `<button class="btn btn-soft btn-sm" onclick="registerEvent(${ev.eventId})">📝 Đăng ký tham gia</button>`}
                            </div>
                        </div>
                    </div>`).join('') : renderEmpty('Chưa có lịch học offline nào.');
                document.getElementById('offlineScheduleList').innerHTML = offlineHtml;

                // Render Quiz Schedule
                const quizHtml = upcomingQuizzes.length ? upcomingQuizzes.map(q => `
                    <div class="schedule-item" style="border-left: 4px solid #f59e0b;">
                        <div style="text-align:center; padding:10px; background:#fff7ed; border-radius:12px;">
                            <div class="schedule-day" style="color:#f59e0b">${new Date(q.startTime).toLocaleDateString('vi-VN', { weekday: 'short' })}</div>
                            <div style="font-size:20px; font-weight:800; color:#7c2d12;">${new Date(q.startTime).getDate()}</div>
                        </div>
                        <div style="flex:1">
                            <div style="font-size:16px; font-weight:800; color:#0f172a">${escapeHtml(q.title)}</div>
                            <div class="meta-line">📚 Khóa học: ${escapeHtml(q.courseTitle)}</div>
                            <div class="meta-line">⏰ Thời gian làm bài: ${q.durationMinutes} phút</div>
                            <div style="margin-top:8px; display:flex; justify-content:space-between; align-items:center">
                                <div style="font-size:12px; font-weight:700; color:#d97706;">Sẽ mở lúc: ${fmtDateTime(q.startTime)}</div>
                                <a class="btn btn-primary btn-sm" href="/Student/Learn/${q.courseId}">Vào chuẩn bị</a>
                            </div>
                        </div>
                    </div>`).join('') : renderEmpty('Chưa có lịch thi nào sắp tới.');
                document.getElementById('quizScheduleList').innerHTML = quizHtml;

                // Dashboard summary (combine first few items)
                const dashHtml = [...offlineEvents.slice(0, 2), ...upcomingQuizzes.slice(0, 2)]
                    .sort((a,b) => new Date(a.startTime) - new Date(b.startTime))
                    .map(item => `<div style="margin-bottom:12px; padding-bottom:12px; border-bottom:1px solid #f1f5f9;">
                        <div style="font-weight:700; font-size:14px;">${escapeHtml(item.title || item.courseTitle)}</div>
                        <div style="font-size:12px; color:var(--text-secondary)">${fmtDateTime(item.startTime)}</div>
                    </div>`).join('') || renderEmpty('Chưa có lịch học.');
                document.getElementById('dashboardSchedule').innerHTML = dashHtml;

            } catch (e) { console.error(e); }
        }

        function isAttendanceTime(ev) {
            if (!ev.attendanceStartTime || !ev.attendanceEndTime) return false;
            const now = new Date();
            return now >= new Date(ev.attendanceStartTime) && now <= new Date(ev.attendanceEndTime);
        }

        async function studentCheckIn(eventId) {
            try {
                await apiFetch(`/api/student/checkin/${eventId}`, { method: 'POST' });
                showToast('Điểm danh thành công!', 'success');
                loadStudySchedule();
            } catch (e) {
                showToast(e.message, 'error');
            }
        }

        function fmtTime(dateStr) {
            if (!dateStr) return '--:--';
            const d = new Date(dateStr);
            if (isNaN(d.getTime())) return '--:--';
            return d.getHours().toString().padStart(2, '0') + ':' + d.getMinutes().toString().padStart(2, '0');
        }

        function renderStudyScheduleCalendar() {
            const weekdays = ['CN', 'Th 2', 'Th 3', 'Th 4', 'Th 5', 'Th 6', 'Th 7'];
            document.getElementById('studyScheduleWeekdays').innerHTML = weekdays.map(day => `<div class="calendar-head">${day}</div>`).join('');

            const current = new Date(state.scheduleMonth.getFullYear(), state.scheduleMonth.getMonth(), 1);
            const start = new Date(current);
            start.setDate(1 - start.getDay());
            const title = current.toLocaleDateString('vi-VN', { month: 'long', year: 'numeric' });
            document.getElementById('studyScheduleTitle').textContent = title.charAt(0).toUpperCase() + title.slice(1);

            const todayKey = new Date().toISOString().slice(0, 10);
            const itemsByDate = state.scheduleItems.reduce((acc, item) => {
                const key = new Date(item.date).toISOString().slice(0, 10);
                if (!acc[key]) acc[key] = [];
                acc[key].push(item);
                return acc;
            }, {});

            const cells = [];
            for (let i = 0; i < 42; i++) {
                const cellDate = new Date(start);
                cellDate.setDate(start.getDate() + i);
                const key = cellDate.toISOString().slice(0, 10);
                const events = itemsByDate[key] || [];
                const isCurrentMonth = cellDate.getMonth() === current.getMonth();
                const isToday = key === todayKey;
                const eventHtml = events.slice(0, 2).map(item => `<div class="calendar-event ${/Bài kiểm tra/i.test(item.title) ? 'exam' : ''}">${escapeHtml(item.title)}</div>`).join('')
                    + (events.length > 2 ? `<div class="calendar-event more">+${events.length - 2} sự kiện</div>` : '');
                cells.push(`
                    <div class="calendar-cell ${isCurrentMonth ? '' : 'muted'} ${isToday ? 'today' : ''}">
                        <div class="calendar-day-number">${cellDate.getDate()}</div>
                        ${eventHtml}
                    </div>
                `);
            }
            document.getElementById('studyScheduleCalendar').innerHTML = cells.join('');
        }

        function moveScheduleMonth(offset) {
            state.scheduleMonth = new Date(state.scheduleMonth.getFullYear(), state.scheduleMonth.getMonth() + offset, 1);
            renderStudyScheduleCalendar();
        }

        function jumpScheduleToday() {
            state.scheduleMonth = new Date();
            renderStudyScheduleCalendar();
        }

        async function loadExamHistory() {
            state.examHistory = await apiFetch('/api/student/exam-history');
            document.getElementById('examHistoryBody').innerHTML = state.examHistory.length ? state.examHistory.map(x => {
                const percent = x.passScore > 0 ? Math.round((x.score / x.passScore) * 100) : 0;
                // Nếu điểm đỗ là 50 và họ làm đúng hết thì percent có thể là 200% nếu ta tính theo passScore.
                // Thường ta chia cho MaxScore. Giả sử passScore là điểm cần đạt (50) và tổng điểm các câu là 50.
                return `
                <tr>
                    <td><strong>${escapeHtml(x.examTitle || '--')}</strong></td>
                    <td>${escapeHtml(x.courseTitle || '--')}</td>
                    <td><span style="font-weight:800; color:${x.isPassed ? 'var(--success)' : 'var(--brand)'}">${x.score}%</span></td>
                    <td>${x.isPassed ? '<span class="badge badge-success">Đạt</span>' : '<span class="badge badge-warning">Chưa đạt</span>'}</td>
                    <td>${fmtDateTime(x.startTime)}</td>
                    <td><button class="btn btn-soft btn-sm" onclick="reviewQuiz(${x.userExamId})">Xem lại</button></td>
                </tr>`;
            }).join('') : '<tr><td colspan="6" style="text-align:center;color:#ef4444;padding:24px">Chưa có dữ liệu lịch sử thi.</td></tr>';
        }

        async function reviewQuiz(userExamId) {
            try {
                const content = document.getElementById('reviewContent');
                content.innerHTML = '<div style="text-align:center; padding: 60px;"><span class="spinner-small"></span> Đang tải dữ liệu bài thi...</div>';
                openModal('reviewModal');

                const data = await apiFetch(`/api/student/quiz-results/${userExamId}`);
                document.getElementById('reviewTitle').textContent = data.examTitle || 'Xem lại bài thi';
                const passBadge = data.isPassed ? '<span class="badge badge-success">ĐẠT</span>' : '<span class="badge badge-danger">KHÔNG ĐẠT</span>';
                document.getElementById('reviewSub').innerHTML = `Kết quả: <strong style="color:#fff">${data.score}%</strong> - ${passBadge}`;
                
                if (!data.questions || data.questions.length === 0) {
                    content.innerHTML = `
                        <div style="text-align:center; padding: 80px;">
                            <div style="font-size: 64px; margin-bottom: 24px;">📭</div>
                            <div style="font-size: 20px; font-weight: 800; color: var(--ink)">Không tìm thấy dữ liệu câu hỏi</div>
                            <div style="color: var(--muted); margin-top: 12px;">Bài thi này có thể đã bị thay đổi cấu trúc hoặc câu hỏi đã bị gỡ bỏ sau khi thi.</div>
                        </div>`;
                    return;
                }

                const html = data.questions.map((q, idx) => {
                    const isCorrect = q.isCorrect;
                    return `
                        <div class="glass-card" style="padding: 28px; border-left: 6px solid ${isCorrect ? '#22c55e' : '#ef4444'}; background: #fff; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
                                <div style="flex: 1;">
                                    <div style="font-size: 13px; font-weight: 800; color: var(--brand); text-transform: uppercase; margin-bottom: 8px;">CÂU HỎI ${idx + 1}</div>
                                    <h3 style="font-size: 18px; font-weight: 700; color: var(--ink); line-height: 1.5; margin: 0;">${escapeHtml(q.questionText)}</h3>
                                </div>
                                <div style="padding: 8px 16px; border-radius: 12px; font-weight: 800; font-size: 12px; border: 1px solid ${isCorrect ? '#22c55e' : '#ef4444'}; color: ${isCorrect ? '#16a34a' : '#dc2626'}; background: ${isCorrect ? '#f0fdf4' : '#fef2f2'};">
                                    ${isCorrect ? 'CHÍNH XÁC ✓' : 'CHƯA ĐÚNG ✗'}
                                </div>
                            </div>
                            <div style="display: grid; gap: 12px;">
                                ${q.options.map(o => {
                                    let border = "1px solid var(--border)";
                                    let bg = "#fff";
                                    let icon = "⚪";
                                    let color = "var(--ink)";
                                    let tag = "";

                                    if (o.isSelected && o.isCorrect) {
                                        border = "2px solid #22c55e"; bg = "#f0fdf4"; icon = "✅"; color = "#16a34a"; tag = '<span style="font-size: 11px; font-weight: 800; margin-left: auto;">BẠN ĐÃ CHỌN ĐÚNG</span>';
                                    } else if (o.isSelected && !o.isCorrect) {
                                        border = "2px solid #ef4444"; bg = "#fef2f2"; icon = "❌"; color = "#b91c1c"; tag = '<span style="font-size: 11px; font-weight: 800; margin-left: auto;">LỰA CHỌN CỦA BẠN</span>';
                                    } else if (!o.isSelected && o.isCorrect) {
                                        border = "2px dashed #22c55e"; bg = "#fff"; icon = "⭐"; color = "#16a34a"; tag = '<span style="font-size: 11px; font-weight: 800; margin-left: auto;">ĐÁP ÁN ĐÚNG</span>';
                                    }

                                    return `
                                        <div style="display: flex; align-items: center; gap: 14px; padding: 16px 20px; border-radius: 14px; transition: all 0.2s; border: ${border}; background: ${bg}; color: ${color};">
                                            <span style="font-size: 18px;">${icon}</span>
                                            <span style="font-size: 15px; font-weight: 600;">${escapeHtml(o.optionText)}</span>
                                            ${tag}
                                        </div>`;
                                }).join('')}
                            </div>
                        </div>`;
                }).join('');
                
                content.innerHTML = html;
            } catch (e) {
                showToast('Không thể tải chi tiết bài thi: ' + e.message, 'error');
                closeModal('reviewModal');
            }
        }

