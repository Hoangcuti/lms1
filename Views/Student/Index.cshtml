            document.getElementById('courseModalSub').textContent = `Danh mục: ${data.category || 'Chung'}`;
            document.getElementById('courseDetailWrap').innerHTML = `
                <div class="info-item"><div class="meta-line">Mô tả</div><div><strong>${escapeHtml(data.description || 'Chưa có mô tả')}</strong></div></div>
                <div class="info-item"><div class="meta-line">Số chương</div><div><strong>${fmtNumber(data.totalModules || 0)}</strong></div></div>
                <div class="info-item"><div class="meta-line">Số bài học</div><div><strong>${fmtNumber(data.totalLessons || 0)}</strong></div></div>
                <div class="info-item"><div class="meta-line">Số bài kiểm tra</div><div><strong>${fmtNumber(data.totalQuizzes || 0)}</strong></div></div>`;
