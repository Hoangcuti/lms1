@{
    Layout = null;
    int courseId = ViewBag.CourseId;
    string courseTitle = ViewBag.CourseTitle ?? "Khóa học";
    int initialProgress = ViewBag.Progress ?? 0;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@courseTitle - LMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://www.youtube.com/iframe_api"></script>
    <script src="~/js/app.js"></script>
    <style>
        :root {
            --brand: #6366f1;
            --brand-light: #818cf8;
            --brand-dark: #4f46e5;
            --brand-2: #2dd4bf;
            --bg: #f8fafc;
            --ink: #0f172a;
            --muted: #64748b;
            --line: rgba(226, 232, 240, 0.4);
            --card-bg: rgba(255, 255, 255, 0.88);
            --sidebar-bg: #0f172a;
            --eval-grad: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(45, 212, 191, 0.05));
            --success: #10b981;
            --warning: #f59e0b;
            --radius-xl: 24px;
            --radius-2xl: 32px;
            --shadow-premium: 0 20px 50px rgba(15, 23, 42, 0.06);
        }

        * { box-sizing: border-box; font-family: 'Manrope', sans-serif; -webkit-font-smoothing: antialiased; }

        body {
            margin: 0;
            background: 
                radial-gradient(circle at 0% 0%, rgba(99, 102, 241, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 100% 100%, rgba(45, 212, 191, 0.08) 0%, transparent 50%),
                #f1f5f9;
            color: var(--ink);
            /* Remove overflow:hidden to allow browser to handle mouse events better */
        }
        
        .layout { display: block; min-height: 100vh; }

        /* Sidebar Styling */
        .side {
            background: var(--sidebar-bg);
            color: #fff;
            padding: 24px 20px;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            width: 340px;
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            overflow-y: auto;
            z-index: 1000;
            box-shadow: 20px 0 60px rgba(0,0,0,0.2);
        }
        
        .side::-webkit-scrollbar { width: 4px; }
        .side::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }

        .brand { margin-bottom: 32px; animation: slideInLeft 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
        .back { color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 700; transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px; opacity: 0.7; }
        .back:hover { color: #fff; opacity: 1; transform: translateX(-4px); }
        .title { font-size: 26px; font-weight: 800; line-height: 1.25; margin: 16px 0 8px; letter-spacing: -0.02em; }

        .meter {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border-radius: var(--radius-xl);
            padding: 24px;
            margin-bottom: 24px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            animation: fadeIn 0.8s ease-out;
            transition: transform 0.3s;
        }
        .meter:hover { transform: translateY(-2px); border-color: rgba(255, 255, 255, 0.15); }
        .meter-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(255,255,255,0.4); font-weight: 800; }
        .progress-val { font-size: 36px; font-weight: 800; margin-top: 4px; display: block; background: linear-gradient(135deg, #fff, rgba(255,255,255,0.5)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .meter-bar { height: 10px; background: rgba(255, 255, 255, 0.05); border-radius: 999px; margin-top: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); }
        .meter-fill { height: 100%; background: linear-gradient(90deg, var(--brand), var(--brand-2)); border-radius: 999px; transition: width 1.2s cubic-bezier(0.34, 1.56, 0.64, 1); box-shadow: 0 0 20px rgba(99, 102, 241, 0.5); position: relative; overflow: hidden; }
        .meter-fill::after { content: ''; position: absolute; top:0; left:0; right:0; bottom:0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); animation: shimmer 2s infinite; }

        .eval {
            background: linear-gradient(135deg, rgba(255,255,255,0.05), rgba(255,255,255,0.01));
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: var(--radius-xl);
            padding: 20px;
            margin-bottom: 24px;
            font-size: 13px;
            transition: all 0.3s;
        }
        .eval:hover { background: rgba(255,255,255,0.07); }

        .tabs { display: flex; background: rgba(0,0,0,0.3); padding: 5px; border-radius: 18px; margin-bottom: 24px; position: relative; }
        .tab { flex: 1; border: 0; background: transparent; color: rgba(255,255,255,0.5); padding: 12px; border-radius: 14px; cursor: pointer; font-weight: 700; font-size: 13px; transition: all 0.3s; z-index: 1; }
        .tab.active { background: #fff; color: var(--ink); box-shadow: 0 8px 16px rgba(0,0,0,0.2); }

        .list { padding-right: 8px; scroll-behavior: smooth; }
        .list::-webkit-scrollbar { width: 5px; }
        .list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
        .list::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

        .group { margin-bottom: 28px; }
        .group-title { font-size: 11px; color: rgba(255,255,255,0.3); font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 14px 12px; display: flex; align-items: center; gap: 10px; }
        .group-title::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.05); }
        
        .item { 
            padding: 16px; border-radius: 20px; margin-bottom: 10px; cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            border: 1px solid transparent; background: rgba(255,255,255,0.02);
            position: relative; overflow: hidden;
        }
        .item:hover { background: rgba(255,255,255,0.06); transform: translateX(4px); border-color: rgba(255,255,255,0.1); }
        .item.active { background: linear-gradient(135deg, rgba(99, 102, 241, 0.4), rgba(99, 102, 241, 0.1)); border-color: var(--brand); box-shadow: 0 10px 25px rgba(99, 102, 241, 0.2); }
        .item.active::before { content: ''; position: absolute; left: 0; top: 0; height: 100%; width: 6px; background: var(--brand); border-radius: 0 4px 4px 0; box-shadow: 0 0 15px var(--brand); }
        
        .item-title { font-size: 14px; font-weight: 700; line-height: 1.5; color: rgba(255,255,255,0.9); }
        .item.active .item-title { color: #fff; }
        .item-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; font-size: 11px; color: rgba(255,255,255,0.4); font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; }
        .status-badge { padding: 4px 10px; border-radius: 8px; background: rgba(255,255,255,0.05); transition: all 0.3s; }
        .item.active .status-badge { background: var(--brand); color: #fff; box-shadow: 0 4px 10px rgba(99, 102, 241, 0.3); }

        .ai-summary-btn {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(45, 212, 191, 0.2));
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s;
            margin-right: 12px;
            backdrop-filter: blur(4px);
        }
        .ai-summary-btn:hover {
            background: var(--brand);
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(99, 102, 241, 0.4);
        }

        /* Modal AI Summary */
        .ai-modal {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(12px);
            z-index: 2000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 24px;
            animation: fadeIn 0.4s ease-out;
        }
        .ai-modal-box {
            background: #fff;
            width: 100%;
            max-width: 800px;
            max-height: 85vh;
            border-radius: var(--radius-2xl);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .ai-modal-header {
            padding: 24px 32px;
            border-bottom: 1px solid var(--line);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(to right, #f8fafc, #fff);
        }
        .ai-modal-body {
            padding: 32px;
            overflow-y: auto;
            flex: 1;
            line-height: 1.8;
            font-size: 16px;
            color: #334155;
        }
        .ai-modal-body h2, .ai-modal-body h3 { color: var(--ink); margin-top: 0; }
        .ai-modal-body ul { padding-left: 20px; }
        .ai-modal-body p { margin-bottom: 20px; }
        
        .close-ai-modal {
            background: var(--bg);
            border: 0;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            transition: all 0.3s;
        }
        .close-ai-modal:hover { background: #f1f5f9; transform: rotate(90deg); }

        @@keyframes slideUp { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* Main Content */
        .main { margin-left: 340px; padding: 32px; display: flex; flex-direction: column; gap: 32px; position: relative; scroll-behavior: smooth; }

        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.7);
            border-radius: var(--radius-2xl);
            box-shadow: var(--shadow-premium);
            padding: 32px;
            animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
        }

        .hero { display: grid; grid-template-columns: 1fr 360px; gap: 32px; align-items: start; }
        
        .viewer { flex: 1; padding: 0 !important; overflow: hidden; border: 1px solid var(--line); }
        .viewer-header { padding: 28px 32px; border-bottom: 1px solid var(--line); background: rgba(255,255,255,0.5); }
        .viewer-body { padding: 0; }
        .viewer video, .viewer iframe { width: 100%; height: 520px; border: 0; background: #000; display: block; transition: opacity 0.5s; }
        
        #contentHost .doc { padding: 40px; font-size: 17px; line-height: 1.8; color: #334155; max-width: 900px; margin: 0 auto; }
        #contentHost .doc h1, #contentHost .doc h2 { color: var(--ink); margin-top: 0; font-weight: 800; letter-spacing: -0.02em; }

        .kpi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 24px 0; }
        .kpi-card { 
            background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 20px; text-align: center; 
            transition: all 0.3s;
        }
        .kpi-card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.05); border-color: var(--brand-light); }
        .kpi-label { font-size: 11px; color: var(--muted); font-weight: 850; display: block; text-transform: uppercase; letter-spacing: 0.1em; }
        .kpi-val { font-size: 32px; font-weight: 800; color: var(--ink); margin-top: 6px; display: block; letter-spacing: -0.02em; }

        .note-card { 
            background: linear-gradient(135deg, #e0e7ff 0%, #d1fae5 100%); 
            border: 1px solid rgba(99, 102, 241, 0.1); 
            border-radius: 24px; padding: 24px; 
            font-size: 14px; line-height: 1.6; color: #3730a3; font-weight: 600;
            box-shadow: inset 0 2px 4px rgba(255,255,255,0.5);
        }

        .actions { display: flex; justify-content: space-between; align-items: center; gap: 16px; width: 100%; }
        .btn { 
            border: 0; border-radius: 18px; padding: 16px 32px; font-weight: 800; font-size: 15px; 
            cursor: pointer; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
            display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-primary { background: linear-gradient(135deg, var(--brand), var(--brand-dark)); color: #fff; box-shadow: 0 12px 24px rgba(99, 102, 241, 0.3); }
        .btn-primary:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 15px 30px rgba(99, 102, 241, 0.4); }
        .btn-soft { background: #fff; color: var(--ink); border: 1px solid var(--line); }
        .btn-soft:hover { background: #f8fafc; transform: translateY(-2px); border-color: var(--brand-light); }

        /* Tabs Bottom */
        .bottom-tabs { 
            display: flex; gap: 12px; margin-bottom: 24px; border-bottom: 1px solid var(--line); padding-bottom: 16px;
        }
        .btab { 
            background: transparent; border: 0; color: var(--muted); font-weight: 800; font-size: 15px; 
            padding: 10px 20px; cursor: pointer; position: relative; transition: all 0.3s; border-radius: 12px;
        }
        .btab:hover { color: var(--ink); background: rgba(0,0,0,0.02); }
        .btab.active { color: var(--brand); background: rgba(99, 102, 241, 0.05); }
        .btab.active::after { content: ''; position: absolute; bottom: -17px; left: 10%; width: 80%; height: 4px; background: var(--brand); border-radius: 10px; }

        .attach-item { 
            display: flex; align-items: center; gap: 20px; padding: 20px; border-radius: 20px; 
            background: #fff; border: 1px solid var(--line); margin-bottom: 12px; transition: all 0.3s;
        }
        .attach-item:hover { transform: translateX(10px) scale(1.01); border-color: var(--brand); box-shadow: 0 10px 25px rgba(0,0,0,0.04); }
        
        .comment-input-wrap {
            display: flex; gap: 16px; align-items: flex-end; background: #fff; padding: 16px; 
            border-radius: 28px; border: 1px solid var(--line); box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            transition: all 0.3s;
        }
        .comment-input-wrap:focus-within { border-color: var(--brand); box-shadow: 0 8px 25px rgba(99, 102, 241, 0.1); }
        
        .comment-input { 
            width: 100%; border: 0; background: transparent; padding: 8px; 
            font-size: 15px; min-height: 44px; outline: none; resize: none;
        }

        /* Animations */
        @@keyframes slideInLeft { from { opacity: 0; transform: translateX(-40px); } to { opacity: 1; transform: translateX(0); } }
        @@keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @@keyframes spin { to { transform: rotate(360deg); } }
        @@keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }

        .shimmer {
            background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0) 100%);
            background-size: 200% 100%;
            animation: shimmer 2s infinite;
        }

        .glow { box-shadow: 0 0 20px rgba(99, 102, 241, 0.4); }

        .spinner-small { width: 20px; height: 20px; border: 3px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; display: inline-block; animation: spin 0.8s linear infinite; }

        @@media (max-width: 1400px) { .hero { grid-template-columns: 1fr; } .side { width: 320px; } }
        @@media (max-width: 1000px) { .layout { grid-template-columns: 1fr; } .side { height: auto; border-right: 0; border-bottom: 1px solid var(--line); } }
    </style>
</head>
<body>
<div class="layout">
    <aside class="side">
        <div class="brand">
            <a class="back" href="/Student/Index"><span>←</span> Quay lại dashboard</a>
            <div class="title">@courseTitle</div>
            <div class="muted" style="color: rgba(255,255,255,0.5)">Học tập và phát triển kỹ năng với lộ trình tối ưu.</div>
        </div>

        <div class="meter">
            <span class="meter-label">Tiến độ khóa học</span>
            <span class="progress-val"><span id="progressText">@initialProgress</span>%</span>
            <div class="meter-bar"><div class="meter-fill" id="progressBar"></div></div>
        </div>

        <div class="eval" id="evalBox" style="border-radius: 20px; color: rgba(255,255,255,0.7);">
            @* Chờ Javascript renderEvaluation *@
        </div>

        <div class="tabs">
            <button class="tab active" id="tabLessons" onclick="setTab('lessons')">Bài học</button>
            <button class="tab" id="tabExams" onclick="setTab('exams')">Kiểm tra</button>
        </div>

        <div class="list" id="sideList"></div>
    </aside>

    <main class="main">
        <div class="hero">
            <section class="glass-card viewer">
                <div class="viewer-header">
                    <span id="contentBadge" class="status-badge" style="background: var(--brand); color: #fff; font-size: 10px; font-weight: 800; text-transform: uppercase;">LOADING</span>
                    <h1 id="contentTitle" style="margin: 12px 0 0; font-size: 24px; font-weight: 800; letter-spacing: -0.01em;">Chọn bài học</h1>
                </div>
                <div class="viewer-body" id="contentHost">
                    <div style="text-align:center; padding: 40px; color: var(--muted)">Vui lòng chọn bài học từ thanh điều hướng để bắt đầu.</div>
                </div>
            </section>

            <section class="glass-card" style="padding: 24px;">
                <span class="kpi-label" style="text-align: left; margin-bottom: 12px;">📊 TRẠNG THÁI HIỆN TẠI</span>
                <div class="kpi-grid">
                    <div class="kpi-card">
                        <span class="kpi-label">BÀI HỌC</span>
                        <span class="kpi-val" id="kpiLessons">0</span>
                    </div>
                    <div class="kpi-card">
                        <span class="kpi-label">ĐÃ XONG</span>
                        <span class="kpi-val" id="kpiDone" style="color: var(--success)">0</span>
                    </div>
                    <div class="kpi-card">
                        <span class="kpi-label">QUIZ</span>
                        <span class="kpi-val" id="kpiExams" style="color: var(--brand)">0</span>
                    </div>
                </div>
                
                <div class="note-card" id="summaryBox">
                    <div style="font-size: 11px; text-transform: uppercase; margin-bottom: 6px; opacity: 0.7;">Ghi chú lộ trình</div>
                    <div id="summaryNote">Hãy bắt đầu bài học đầu tiên để thấy đánh giá chi tiết của hệ thống.</div>
                </div>
            </section>
        </div>

        <section class="glass-card" style="padding: 24px;">
            <div class="actions">
                <button class="btn btn-soft" onclick="playNeighbor(-1)">← Bài học trước</button>
                <div style="display:flex; gap: 12px;">
                    <button class="btn btn-primary" id="btnComplete" onclick="markLessonComplete()">Hoàn thành & Tiếp tục →</button>
                </div>
            </div>
        </section>

        <section class="glass-card" id="bottomPanel" style="display:none">
            <div class="bottom-tabs">
                <button class="btab active" id="btabAttach" onclick="setBottomTab('attach')">Tài liệu học tập</button>
                <button class="btab" id="btabComments" onclick="setBottomTab('comments')">Thảo luận bài học</button>
            </div>
            
            <div id="attachPanel">
                <div id="attachList"></div>
            </div>
            
            <div id="commentsPanel" style="display:none">
                <div id="commentsList" style="max-height:320px; overflow-y:auto; margin-bottom: 24px; padding-right: 8px;"></div>
                <div style="display:flex; gap:16px; align-items:flex-end; background: #fff; padding: 12px; border-radius: 24px; border: 1px solid var(--line);">
                    <textarea id="newComment" class="comment-input" style="border:0; padding: 8px; min-height: 44px; max-height: 120px;" placeholder="Chia sẻ cảm nghĩ hoặc thắc mắc của bạn..."></textarea>
                    <button class="btn btn-primary" style="padding: 10px 24px; border-radius: 14px;" onclick="postComment()">Gửi 📤</button>
                </div>
            </div>
        </section>
    </main>
</div>

<!-- Modal AI Summary -->
<div id="aiSummaryModal" class="ai-modal">
    <div class="ai-modal-box">
        <div class="ai-modal-header">
            <div>
                <div style="font-size:12px; text-transform:uppercase; letter-spacing:0.1em; color:var(--brand); font-weight:800; margin-bottom:4px;">✨ AI Chapter Summary</div>
                <div id="aiSummaryTitle" style="font-size:22px; font-weight:800; color:var(--ink)">Tóm tắt chương</div>
            </div>
            <button class="close-ai-modal" onclick="closeAISummary()">✕</button>
        </div>
        <div id="aiSummaryBody" class="ai-modal-body">
            <div style="text-align:center; padding:40px;">
                <div class="spinner" style="margin:0 auto 20px;"></div>
                <div style="color:var(--muted); font-weight:600;">Gemini đang tóm tắt nội dung chương học...</div>
            </div>
        </div>
    </div>
</div>
<script>
const courseId = @courseId;
let curriculum = { modules: [], exams: [], evaluation: null };
let flatLessons = [];
let currentLessonId = null;
let currentTab = 'lessons';
let bottomTab = 'attach';
// Lưu tiến độ xem video từng bài (lessonId -> percent 0-100)
const lessonProgress = {};

function setTab(tab) {
    currentTab = tab;
    document.getElementById('tabLessons').classList.toggle('active', tab === 'lessons');
    document.getElementById('tabExams').classList.toggle('active', tab === 'exams');
    renderSidebar();
}

function setBottomTab(tab) {
    bottomTab = tab;
    document.getElementById('btabAttach').classList.toggle('active', tab === 'attach');
    document.getElementById('btabComments').classList.toggle('active', tab === 'comments');
    document.getElementById('attachPanel').style.display = tab === 'attach' ? '' : 'none';
    document.getElementById('commentsPanel').style.display = tab === 'comments' ? '' : 'none';
    if (tab === 'attach' && currentLessonId) loadAttachments(currentLessonId);
    if (tab === 'comments' && currentLessonId) loadComments(currentLessonId);
}

async function init() {
    console.log("Loading curriculum for course:", courseId);
    const data = await apiFetch(`/api/student/curriculum/${courseId}`);
    console.log("Curriculum Data Response:", data);
    curriculum = data;
    flatLessons = (data.modules || []).flatMap(m => m.lessons || []);
    
    const initialProgress = @Html.Raw(Json.Serialize(ViewBag.Progress ?? 0));

    document.getElementById('kpiLessons').textContent = flatLessons.length;
    document.getElementById('kpiDone').textContent = flatLessons.filter(l => l.isCompleted).length;
    document.getElementById('kpiExams').textContent = (data.exams || []).length;
    
    try {
        const progressPct = data.progressPercent || 0;
        
        // Hiệu ứng chạy số và thanh progress theo dữ liệu từ server
        animateValue("progressText", 0, progressPct, 1500);
        setTimeout(() => {
            const pb = document.getElementById('progressBar');
            if (pb) pb.style.width = progressPct + '%';
        }, 100);

        renderEvaluation();
        renderSidebar();
        const first = flatLessons.find(l => !l.isCompleted) || flatLessons[0];
        if (flatLessons.length > 0) playLesson(first.lessonId);
        else {
            showEmpty();
            if (data.debug && data.debug.modulesCount === 0) {
                document.getElementById('sideList').innerHTML += `<div style="font-size:10px;color:#94a3b8;margin-top:20px;padding:10px;border-top:1px solid #334155">
                    Debug: CourseID=${data.debug.courseId}, Modules=${data.debug.modulesCount}, Exams=${data.debug.examsCount}
                </div>`;
            }
        }
    } catch(err) {
        console.error("Error in init rendering:", err);
        document.getElementById('sideList').innerHTML = `<div class="muted" style="color:#ef4444;padding:20px">Lỗi hiển thị nội dung: ${err.message}</div>`;
    }
}

function renderEvaluation() {
    const e = curriculum.evaluation;
    if (!e) return;
    const rankColors = { 'Xuất sắc': '#10b981', 'Giỏi': '#6366f1', 'Khá': '#f59e0b', 'Trung bình': '#64748b', 'Không đạt': '#ef4444' };
    const rankColor = rankColors[e.ranking] || '#fff';
    document.getElementById('evalBox').innerHTML = `
        <div class="muted" style="color:rgba(255,255,255,0.5)">Xếp loại đề xuất</div>
        <div style="font-size:26px;font-weight:800;margin:8px 0 4px;color:${rankColor}">${e.ranking}</div>
        <div class="muted" style="color:rgba(255,255,255,0.5)">Tổng điểm ${e.weightedScore}% | Quiz TB ${e.quizAverage}%</div>
    `;
    const noteEl = document.getElementById('summaryNote');
    if (noteEl) noteEl.textContent = e.note;
}

function getLessonProgressPct(l) {
    if (l.isCompleted) return 100;
    return Math.round(lessonProgress[l.lessonId] || 0);
}

function renderSidebar() {
    const list = document.getElementById('sideList');
    if (currentTab === 'lessons') {
        list.innerHTML = curriculum.modules.map((m, i) =>
            `<div class="group">
                <div class="group-title" style="display:flex; justify-content:space-between; align-items:center;">
                    <span>Chương ${i + 1}: ${escapeHtml(m.title || '')}</span>
                    <button class="ai-summary-btn" onclick="showModuleSummary(${m.moduleId}, '${escapeHtml(m.title || '')}')" title="Tóm tắt bằng AI">✨ AI</button>
                </div>${
                m.lessons.map(l => {
                    const pct = getLessonProgressPct(l);
                    const isActive = currentLessonId === l.lessonId;
                    const isVideo = l.contentType === 'Video';
                    const barColor = l.isCompleted ? 'var(--success)' : (pct > 0 ? '#f59e0b' : 'rgba(255,255,255,0.1)');
                    const badgeStyle = l.isCompleted ? 'background:var(--success);color:#fff' : (pct > 0 ? 'background:#f59e0b;color:#fff' : '');
                    const badgeText = l.isCompleted ? '✓ Xong' : (pct > 0 ? `${pct}%` : 'Học');
                    return `<div class="item ${isActive ? 'active' : ''}" onclick="playLesson(${l.lessonId})">
                        <div class="item-title">${escapeHtml(l.title || 'Bài học')}</div>
                        <div class="item-meta">
                            <span>${escapeHtml(l.contentType || 'Nội dung')}</span>
                            <span class="status-badge" style="${badgeStyle}">${badgeText}</span>
                        </div>
                        ${isVideo ? `<div style="margin-top:8px;height:4px;background:rgba(255,255,255,0.08);border-radius:99px;overflow:hidden">
                            <div style="height:100%;width:${pct}%;background:${barColor};border-radius:99px;transition:width 0.5s ease"></div>
                        </div>` : ''}
                    </div>`;
                }).join('')
            }</div>`
        ).join('') || '<div class="muted">Chưa có bài học.</div>';
    } else {
        list.innerHTML = (curriculum.exams || []).map((e, idx) => {
            const isDone = e.lastAttempt && e.lastAttempt.isFinish;
            const score = isDone ? e.lastAttempt.score : 0;
            const isPerfect = score >= 100;
            const lockHtml = e.isLocked ? `<div style="position:absolute; inset:0; background:rgba(255,255,255,0.6); backdrop-filter:blur(3px); z-index:2; cursor:not-allowed; display:flex; align-items:center; justify-content:center; color:#1e293b; font-size:10px; font-weight:800;" title="${e.lockReason}">🔒 ${e.lockReason}</div>` : '';
            
            return `<div class="item" style="position:relative;" onclick="${e.isLocked ? `showToast('${e.lockReason}', 'warning')` : `openExam(${e.examId})`}">
                <div class="item-title" style="${isPerfect ? 'color:var(--success)' : ''}">Quiz ${idx + 1}: ${escapeHtml(e.title || 'Bài kiểm tra')}</div>
                <div class="item-meta"><span>${e.questionCount} câu | ${e.durationMinutes} phút</span>
                <span class="status-badge" style="${isPerfect ? 'background:var(--success); color:white; border:none' : (e.isLocked ? 'background:#f1f5f9; color:#94a3b8' : '')}">${isDone ? `${score}%` : (e.isLocked ? 'Khóa' : 'Thi')}</span></div>
                ${lockHtml}
            </div>`;
        }).join('') || '<div class="muted">Không có bài kiểm tra.</div>';
    }
}

function showEmpty() {
    document.getElementById('contentBadge').textContent = 'Sẵn sàng';
    document.getElementById('contentTitle').textContent = 'Khóa học chưa có nội dung';
    document.getElementById('contentHost').innerHTML = '<div class="doc">Bộ phận quản trị chưa thêm bài học hoặc quiz cho khóa học này.</div>';
}

let videoTracker = {
    maxTime: 0,
    duration: 0,
    isCompleted: false,
    ytPlayer: null,
    ytInterval: null,
    lastTime: 0,
    isSeekingCorrection: false
};

function updateVideoProgressUI(pct) {
    // Nếu bài học hiện tại đã hoàn thành trước đó (server confirm), không cập nhật lại UI lùi lại
    if (videoTracker.isCompleted) return;

    // Cập nhật button hoàn thành
    const btn = document.getElementById('btnComplete');
    if (btn) {
        btn.innerHTML = `Hãy xem đủ 90% video &nbsp;<span style="opacity:0.7;font-size:13px">(${Math.round(pct)}%)</span>`;
    }
    // Cập nhật thanh progress trong sidebar (chỉ bài hiện tại đang học dở)
    if (currentLessonId) {
        lessonProgress[currentLessonId] = Math.min(Math.round(pct), 99);
        const items = document.querySelectorAll('#sideList .item');
        items.forEach(item => {
            const onclickAttr = item.getAttribute('onclick') || '';
            const match = onclickAttr.match(/playLesson\((\d+)\)/);
            if (match && parseInt(match[1]) === currentLessonId) {
                const bar = item.querySelector('div[style*="height:4px"] div');
                const badge = item.querySelector('.status-badge');
                if (bar) bar.style.width = Math.round(pct) + '%';
                if (badge) {
                    badge.style.background = '#f59e0b';
                    badge.style.color = '#fff';
                    badge.textContent = Math.round(pct) + '%';
                }
            }
        });
    }
}

function playLesson(id) {
    currentLessonId = id;
    renderSidebar();
    const lesson = flatLessons.find(l => l.lessonId === id);
    if (!lesson) return;

    // Tự động cuộn lên đầu nội dung bài học
    const mainArea = document.querySelector('.main');
    if (mainArea) mainArea.scrollTop = 0;

    // Clear ytInterval cũ nếu có
    if (videoTracker.ytInterval) clearInterval(videoTracker.ytInterval);
    if (videoTracker.saveInterval) clearInterval(videoTracker.saveInterval);

    // Reset tracker for new lesson — restore saved position from localStorage
    const savedPos = parseFloat(localStorage.getItem(`video_pos_${courseId}_${id}`) || '0');
    videoTracker = { maxTime: savedPos, duration: 0, isCompleted: lesson.isCompleted, ytPlayer: null, ytInterval: null, saveInterval: null, lastTime: savedPos, isSeekingCorrection: false };

    // Restore progress UI immediately if has saved data
    if (savedPos > 0 && !lesson.isCompleted) {
        lessonProgress[id] = 0; // will be updated when duration loads
    }

    document.getElementById('contentBadge').textContent = lesson.contentType || 'Bài học';
    document.getElementById('contentTitle').textContent = lesson.title || 'Bài học';
    const host = document.getElementById('contentHost');
    
    // Disable completion button initially for new lesson if not finished
    const btn = document.getElementById('btnComplete');
    if (!lesson.isCompleted) {
        btn.disabled = true;
        btn.style.opacity = '0.5';
        btn.innerHTML = 'Hãy xem đủ 90% video';
    } else {
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.innerHTML = 'Tiếp tục bài tiếp →';
    }

    if (lesson.contentType === 'Video' && lesson.videoUrl) {
        const isYT = lesson.videoUrl.includes('youtube.com') || lesson.videoUrl.includes('youtu.be');
        if (isYT) {
            let videoId = '';
            if (lesson.videoUrl.includes('v=')) {
                videoId = lesson.videoUrl.split('v=')[1].split('&')[0];
            } else if (lesson.videoUrl.includes('youtu.be/')) {
                videoId = lesson.videoUrl.split('youtu.be/')[1].split('?')[0];
            } else if (lesson.videoUrl.includes('embed/')) {
                videoId = lesson.videoUrl.split('embed/')[1].split('?')[0];
            }
            
            host.innerHTML = `<div id="ytPlayerHost" style="border-radius:12px; overflow:hidden; box-shadow:0 10px 30px rgba(0,0,0,0.3)"></div>`;
            videoTracker.ytPlayer = new YT.Player('ytPlayerHost', {
                height: '480',
                width: '100%',
                videoId: videoId,
                playerVars: { 'autoplay': 1, 'controls': 1, 'disablekb': 0, 'modestbranding': 1, 'rel': 0, 'start': Math.floor(videoTracker.maxTime) },
                events: {
                    'onReady': (e) => { 
                        videoTracker.duration = e.target.getDuration();
                        // Resume saved position (YouTube start param may not be exact)
                        if (videoTracker.maxTime > 5) e.target.seekTo(videoTracker.maxTime, true);
                        startYTTracking(); 
                    },
                    'onStateChange': onYTStateChange
                }
            });
            // Save position to localStorage every 5s for YT
            videoTracker.saveInterval = setInterval(() => {
                if (videoTracker.ytPlayer?.getCurrentTime) {
                    const curr = videoTracker.ytPlayer.getCurrentTime();
                    if (curr > 0) localStorage.setItem(`video_pos_${courseId}_${id}`, curr.toFixed(1));
                }
            }, 5000);
        } else {
            host.innerHTML = `<video id="nativeVideo" controls style="width:100%; height:auto; max-height:480px; background:#000; border-radius:12px;">
                                <source src="${lesson.videoUrl}" type="video/mp4">
                              </video>`;
            const video = document.getElementById('nativeVideo');
            video.onloadedmetadata = () => { 
                videoTracker.duration = video.duration;
                // Resume saved position
                if (videoTracker.maxTime > 5) {
                    video.currentTime = videoTracker.maxTime;
                    videoTracker.lastTime = videoTracker.maxTime;
                    showToast(`▶ Tiếp tục từ ${Math.floor(videoTracker.maxTime/60)}:${String(Math.floor(videoTracker.maxTime%60)).padStart(2,'0')}`, 'info');
                }
            };
            video.ontimeupdate = () => { 
                videoTracker.lastTime = video.currentTime;
                handleVideoProgress(video.currentTime);
                // Save position every ~5s (check on timeupdate, save every 5s)
                if (Math.floor(video.currentTime) % 5 === 0 && video.currentTime > 0) {
                    localStorage.setItem(`video_pos_${courseId}_${id}`, video.currentTime.toFixed(1));
                }
            };
            video.onseeking = () => {
                if (videoTracker.isSeekingCorrection) return;
                const allowedTime = Math.max(videoTracker.maxTime, videoTracker.lastTime);
                const delta = video.currentTime - allowedTime;
                if (delta > 1.5) { // Allow tiny buffer
                    videoTracker.isSeekingCorrection = true;
                    video.currentTime = allowedTime;
                    showToast('Bạn không thể xem nhanh qua phần chưa học!', 'warning');
                }
            };
            video.onseeked = () => { videoTracker.isSeekingCorrection = false; };
            video.onplay = () => {
                if (video.currentTime > videoTracker.maxTime + 1.5) {
                    video.currentTime = videoTracker.maxTime;
                }
            };
            video.play();
        }
    } else {
        host.innerHTML = `<div class="doc">${lesson.contentBody || 'Chưa có nội dung chi tiết.'}</div>`;
        btn.disabled = false; btn.style.opacity = '1'; btn.innerHTML = 'Tiếp tục bài tiếp →';
    }
    
    // Luôn hiển thị panel tài liệu khi bài học được chọn
    const bPanel = document.getElementById('bottomPanel');
    if (bPanel) {
        bPanel.style.display = 'block';
        bPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    if (bottomTab === 'attach') loadAttachments(id);
    else loadComments(id);
}

function handleVideoProgress(currentTime) {
    if (currentTime > videoTracker.maxTime) {
        videoTracker.maxTime = currentTime;
    }
    
    if (videoTracker.duration > 0) {
        const percent = (videoTracker.maxTime / videoTracker.duration) * 100;
        // Cập nhật UI progress real-time
        updateVideoProgressUI(Math.min(percent, 99.9));
        
        if (!videoTracker.isCompleted && percent >= 90) {
            videoTracker.isCompleted = true;
            // Cập nhật 100% trước khi gọi complete
            if (currentLessonId) lessonProgress[currentLessonId] = 100;
            // Xóa localStorage khi hoàn thành
            localStorage.removeItem(`video_pos_${courseId}_${currentLessonId}`);
            markLessonComplete(true); // Auto-complete
        }
    }
}

function onYTStateChange(event) {
    if (event.data === YT.PlayerState.PLAYING) {
        startYTTracking();
    }
}

function startYTTracking() {
    if (videoTracker.ytInterval) return;
    videoTracker.ytInterval = setInterval(() => {
        if (!videoTracker.ytPlayer || !videoTracker.ytPlayer.getCurrentTime) return;
        const curr = videoTracker.ytPlayer.getCurrentTime();
        
        // Anti-seek forward for YT - stricter check
        const allowedTime = Math.max(videoTracker.maxTime, videoTracker.lastTime);
        if (curr > allowedTime + 1.5) {
            videoTracker.ytPlayer.seekTo(allowedTime, true);
            showToast('Bạn chỉ có thể xem lại, không được tua nhanh!', 'warning');
        } else {
            videoTracker.lastTime = curr;
            handleVideoProgress(curr);
        }
    }, 500); // Check every 500ms for better responsiveness
}

function playNeighbor(offset) {
    if (videoTracker.ytInterval) clearInterval(videoTracker.ytInterval);
    const idx = flatLessons.findIndex(l => l.lessonId === currentLessonId);
    const next = flatLessons[idx + offset];
    if (next) playLesson(next.lessonId);
}

async function markLessonComplete(isAuto = false) {
    const lesson = flatLessons.find(l => l.lessonId === currentLessonId);
    if (!lesson) return;
    
    const btn = document.getElementById('btnComplete');
    if (!lesson.isCompleted || isAuto) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-small"></span> Đang lưu...';
        try {
            const res = await apiFetch('/api/student/complete-lesson', { method: 'POST', body: JSON.stringify(currentLessonId) });
            lesson.isCompleted = true;
            
            // Cập nhật % toàn khóa học
            if (res.progressPercent !== undefined) {
                animateValue("progressText", parseInt(document.getElementById('progressText').textContent), res.progressPercent, 1000);
                document.getElementById('progressBar').style.width = `${res.progressPercent}%`;
                
                // Cập nhật lại Xếp loại/Evaluation vì tiến độ đã thay đổi
                if (curriculum) {
                    curriculum.progressPercent = res.progressPercent;
                    // Nếu server trả về evaluation mới, cập nhật nó luôn
                    if (res.evaluation) curriculum.evaluation = res.evaluation;
                    renderEvaluation();
                }
            }
            
            document.getElementById('kpiDone').textContent = flatLessons.filter(l => l.isCompleted).length;
            showToast('Chúc mừng! Bạn đã hoàn thành bài giảng.', 'success');
            renderSidebar();
            btn.innerHTML = 'Tiếp tục bài tiếp →';
            btn.disabled = false;
            btn.style.opacity = '1';
        } catch(e) {
            showToast('Lỗi lưu tiến độ: ' + e.message, 'error');
            btn.innerHTML = 'Thử lại';
            btn.disabled = false;
        }
    } else {
        playNeighbor(1);
    }
}

function openExam(examId) {
    window.location.href = `/Student/Quiz/${courseId}/${examId}`;
}

async function showModuleSummary(moduleId, title) {
    document.getElementById('aiSummaryTitle').textContent = `Tóm tắt: ${title}`;
    document.getElementById('aiSummaryModal').style.display = 'flex';
    document.getElementById('aiSummaryBody').innerHTML = `
        <div style="text-align:center; padding:40px;">
            <div class="spinner" style="margin:0 auto 20px;"></div>
            <div style="color:var(--muted); font-weight:600;">Gemini đang tóm tắt nội dung chương học...</div>
        </div>
    `;

    try {
        const data = await apiFetch(`/api/student/modules/${moduleId}/summary-ai`);
        document.getElementById('aiSummaryBody').innerHTML = data.summary || '<div style="color:red">Không thể tạo tóm tắt.</div>';
    } catch (e) {
        document.getElementById('aiSummaryBody').innerHTML = `<div style="color:red; text-align:center; padding:40px;">Lỗi: ${e.message}</div>`;
    }
}

function closeAISummary() {
    document.getElementById('aiSummaryModal').style.display = 'none';
}

async function loadAttachments(lessonId) {
    const el = document.getElementById('attachList');
    el.innerHTML = '<div style="color:#9eb0cf;font-size:13px">Đang tải...</div>';
    try {
        const attachments = await apiFetch(`/api/student/lessons/${lessonId}/attachments`);
        if (!attachments.length) {
            el.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:24px;text-align:center">Bài học này chưa có tài liệu đính kèm.</div>';
            return;
        }
        el.innerHTML = attachments.map(a => `
            <div class="attach-item">
                <span style="font-size:24px">📁</span>
                <div style="flex:1"><div style="font-size:14px;font-weight:700">${escapeHtml(a.fileName || 'Tài liệu')}</div></div>
                ${a.filePath ? `<a href="${escapeHtml(a.filePath)}" target="_blank" class="btn btn-soft" style="padding:10px 20px;font-size:12px;border-radius:12px">Tải xuống</a>` : ''}
            </div>
        `).join('');
    } catch (e) {
        el.innerHTML = '<div style="color:#ef4444;font-size:13px">Lỗi tải dữ liệu.</div>';
    }
}

async function loadComments(lessonId) {
    const el = document.getElementById('commentsList');
    el.innerHTML = '<div style="color:#9eb0cf;font-size:13px">Đang tải thảo luận...</div>';
    try {
        const comments = await apiFetch(`/api/student/lessons/${lessonId}/comments`);
        if (!comments.length) {
            el.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:24px;text-align:center">Chưa có thảo luận nào cho bài học này.</div>';
            return;
        }
        el.innerHTML = comments.map(c => `
            <div style="margin-bottom:20px; display:flex; gap:12px;">
                <div style="width:36px; height:36px; border-radius:12px; background:var(--eval-grad); display:flex; align-items:center; justify-content:center; font-weight:800; color:var(--brand); font-size:14px">${(c.userName || 'U')[0].toUpperCase()}</div>
                <div style="flex:1">
                    <div style="display:flex; justify-content:space-between; align-items:center">
                        <span style="font-size:13px; font-weight:800; color:var(--ink)">${c.isOwn ? 'Bạn' : escapeHtml(c.userName)}</span>
                    </div>
                    <div style="margin-top:4px; font-size:14px; line-height:1.5; color:#475569">${escapeHtml(c.content || '')}</div>
                </div>
            </div>
        `).join('');
    } catch (e) {
        el.innerHTML = '<div style="color:#ef4444;font-size:13px">Lỗi kết nối.</div>';
    }
}

async function postComment() {
    const input = document.getElementById('newComment');
    const content = input.value.trim();
    if (!content || !currentLessonId) return;
    try {
        await apiFetch(`/api/student/lessons/${currentLessonId}/comments`, {
            method: 'POST',
            body: JSON.stringify({ content })
        });
        input.value = '';
        showToast('Đã đăng thảo luận!', 'success');
        await loadComments(currentLessonId);
    } catch (e) {
        showToast(e.message || 'Lỗi gửi bình luận', 'error');
    }
}

function animateValue(id, start, end, duration) {
    const obj = document.getElementById(id);
    if (!obj) return;
    let startTimestamp = null;
    const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const val = Math.floor(progress * (end - start) + start);
        obj.innerHTML = val;
        if (progress < 1) {
            window.requestAnimationFrame(step);
        }
    };
    window.requestAnimationFrame(step);
}

function escapeHtml(str) {
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

document.addEventListener('DOMContentLoaded', () => init().catch(err => {
    console.error(err);
    showToast(err.message || 'Không thể tải khóa học', 'error');
    showEmpty();
}));
</script>
</body>
</html>
